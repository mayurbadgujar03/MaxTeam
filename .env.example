PORT=8000
MONGO_URI=addmongourlhere
ACCESS_TOKEN_SECRET=somethinggoeshere
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=somethinggoeshere
REFRESH_TOKEN_EXPIRY=1d

# Code Track — GitHub Personal Access Token (optional but strongly recommended)
# Without this, unauthenticated GitHub API calls are limited to 60 requests/hour.
# Generate at: https://github.com/settings/tokens (needs repo:public_repo scope)
GITHUB_PAT=your_github_pat_here